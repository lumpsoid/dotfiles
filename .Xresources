!xterm config
*.termName: xterm-256color
*locale: UTF-8
*.vt100.utf8: true
*.vt100.saveLines: 4096
!*.vt100.selectToClipboard: true
*.vt100.faceName: MesloLGS NF
*.vt100.faceSize: 10

*vt100*translations: #override \
    Ctrl<Key>BackSpace: string("\033[7;5~")
!keycode 22
! theam
!*foreground: green
!*background: black

! Dracula Xresources palette
*.foreground: #F8F8F2
*.background: #282A36
*.color0:     #000000
*.color8:     #4D4D4D
*.color1:     #FF5555
*.color9:     #FF6E67
*.color2:     #50FA7B
*.color10:    #5AF78E
*.color3:     #F1FA8C
*.color11:    #F4F99D
*.color4:     #BD93F9
*.color12:    #CAA9FA
*.color5:     #FF79C6
*.color13:    #FF92D0
*.color6:     #8BE9FD
*.color14:    #9AEDFE
*.color7:     #BFBFBF
*.color15:    #E6E6E6
